<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  Анимация перемещения вниз (вниз и обратно при AutoReverse)  -->
    <Storyboard x:Key="MoveUpDownStoryboard">
        <DoubleAnimation
            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
            From="0"
            To="20"
            Duration="0:0:5">
            
        </DoubleAnimation>
    </Storyboard>

    <!--  Анимация затухания (исчезновение совпадений)  -->
    <Storyboard x:Key="FadeOutStoryboard">
        <DoubleAnimation
            Storyboard.TargetProperty="Opacity"
            From="1"
            To="0"
            Duration="0:0:1" />
    </Storyboard>

    <!--  Анимация появления (новые фигуры сверху)  -->
    <Storyboard x:Key="FadeInStoryboard">
        <DoubleAnimation
            Storyboard.TargetProperty="Opacity"
            From="0"
            To="1"
            Duration="0:0:1" />
    </Storyboard>

</ResourceDictionary>
