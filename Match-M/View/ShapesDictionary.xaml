<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:model="clr-namespace:Match_M.Model">

    <!--  Отображение новой ячейки Cell с векторной фигурой (Path)  -->
    <DataTemplate DataType="{x:Type model:Cell}">
        <Button
            Padding="0"
            Background="Transparent"
            BorderThickness="0"
            Command="{Binding DataContext.ToggleCellSelectionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
            CommandParameter="{Binding}">
            <Border
                Width="75"
                Height="75"
                Margin="3"
                CornerRadius="6">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#444" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <!--  Цвет фона при нажатой/выбранной ячейке  -->
                                <Setter Property="Background" Value="#5566FF" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Viewbox HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Path Stretch="Uniform">
                        <Path.Style>
                            <Style TargetType="Path">
                                <!--  Пустая фигура по умолчанию  -->
                                <Setter Property="Data" Value="M0,0" />
                                <!--  Единый внутренний отступ для всех фигур  -->
                                <Setter Property="Margin" Value="15" />
                                <Style.Triggers>
                                    <!--  Квадрат  -->
                                    <DataTrigger Binding="{Binding Shape}" Value="{x:Static model:ShapeType.Square}">
                                        <Setter Property="Data" Value="M10,10 L90,10 L90,90 L10,90 Z" />
                                        <Setter Property="Fill" Value="#3FA9F5" />
                                    </DataTrigger>
                                    <!--  Круг  -->
                                    <DataTrigger Binding="{Binding Shape}" Value="{x:Static model:ShapeType.Circle}">
                                        <Setter Property="Data" Value="M50,20 A30,30 0 1 1 49.9,20 Z" />
                                        <Setter Property="Fill" Value="#FF9F1C" />
                                    </DataTrigger>
                                    <!--  Треугольник  -->
                                    <DataTrigger Binding="{Binding Shape}" Value="{x:Static model:ShapeType.Triangle}">
                                        <Setter Property="Data" Value="M50,15 L85,85 L15,85 Z" />
                                        <Setter Property="Fill" Value="#2ECC71" />
                                    </DataTrigger>
                                    <!--  Ромб  -->
                                    <DataTrigger Binding="{Binding Shape}" Value="{x:Static model:ShapeType.Diamond}">
                                        <Setter Property="Data" Value="M50,15 L85,50 L50,85 L15,50 Z" />
                                        <Setter Property="Fill" Value="#9B59B6" />
                                    </DataTrigger>
                                    <!--  Звезда  -->
                                    <DataTrigger Binding="{Binding Shape}" Value="{x:Static model:ShapeType.Star}">
                                        <Setter Property="Data" Value="M50,15 L58,35 L80,35 L62,50 L69,72 L50,60 L31,72 L38,50 L20,35 L42,35 Z" />
                                        <Setter Property="Fill" Value="#F1C40F" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Viewbox>
            </Border>
        </Button>
    </DataTemplate>

</ResourceDictionary>
