<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behavior="clr-namespace:Match_M.Behaviors"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:model="clr-namespace:Match_M.Model">

    <!--  Отображение новой ячейки Cell с векторной фигурой (Path)  -->
    <DataTemplate DataType="{x:Type model:Cell}">
        <Button
            Padding="0"
            Background="Transparent"
            BorderThickness="0"
            Command="{Binding DataContext.ToggleCellSelectionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
            CommandParameter="{Binding}">
            <Border
                Width="75"
                Height="75"
                Margin="3"
                CornerRadius="6"
                behavior:AnimationBehavior.Animation="{Binding Animation}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#444" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <!--  Цвет фона при нажатой/выбранной ячейке  -->
                                <Setter Property="Background" Value="#5566FF" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Viewbox HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Path Stretch="Uniform">
                        <Path.Style>
                            <Style TargetType="Path">
                                <!--  Пустая фигура по умолчанию  -->
                                <Setter Property="Data" Value="M0,0" />
                                <Setter Property="Fill" Value="Transparent" />
                                <!--  Единый внутренний отступ для всех фигур  -->
                                <Setter Property="Margin" Value="15" />
                                <Style.Triggers>
                                    <!--  Пусто  -->
                                    <DataTrigger Binding="{Binding Shape}" Value="{x:Static model:ShapeType.None}">
                                        <Setter Property="Data" Value="M0,0" />
                                        <Setter Property="Fill" Value="Transparent" />
                                    </DataTrigger>
                                    <!--  Квадрат  -->
                                    <DataTrigger Binding="{Binding Shape}" Value="{x:Static model:ShapeType.Square}">
                                        <Setter Property="Data" Value="M10,10 L90,10 L90,90 L10,90 Z" />
                                        <Setter Property="Fill" Value="#3FA9F5" />
                                    </DataTrigger>
                                    <!--  Круг  -->
                                    <DataTrigger Binding="{Binding Shape}" Value="{x:Static model:ShapeType.Circle}">
                                        <Setter Property="Data" Value="M50,20 A30,30 0 1 1 49.9,20 Z" />
                                        <Setter Property="Fill" Value="#FF9F1C" />
                                    </DataTrigger>
                                    <!--  Треугольник  -->
                                    <DataTrigger Binding="{Binding Shape}" Value="{x:Static model:ShapeType.Triangle}">
                                        <Setter Property="Data" Value="M50,15 L85,85 L15,85 Z" />
                                        <Setter Property="Fill" Value="#2ECC71" />
                                    </DataTrigger>
                                    <!--  Ромб  -->
                                    <DataTrigger Binding="{Binding Shape}" Value="{x:Static model:ShapeType.Diamond}">
                                        <Setter Property="Data" Value="M50,15 L85,50 L50,85 L15,50 Z" />
                                        <Setter Property="Fill" Value="#9B59B6" />
                                    </DataTrigger>
                                    <!--  Звезда  -->
                                    <DataTrigger Binding="{Binding Shape}" Value="{x:Static model:ShapeType.Star}">
                                        <Setter Property="Data" Value="M50,15 L58,35 L80,35 L62,50 L69,72 L50,60 L31,72 L38,50 L20,35 L42,35 Z" />
                                        <Setter Property="Fill" Value="#F1C40F" />
                                    </DataTrigger>

                                    <!--  Line‑бонусы: горизонтальный / вертикальный.
                                          Определяются по BonusType, цвет берём из Shape.  -->

                                    <!--  LineBonus Horizontal (стрелка ↔) -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Bonus}" Value="{x:Static model:BonusType.HLine}" />
                                            <Condition Binding="{Binding Shape}" Value="{x:Static model:ShapeType.Square}" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Data" Value="M15,50 L25,45 L25,47 L75,47 L75,43 L85,50 L75,57 L75,53 L25,53 L25,55 Z" />
                                        <Setter Property="Fill" Value="#3FA9F5" />
                                    </MultiDataTrigger>
                                    <!--  LineBonus Vertical (стрелка ↨) -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Bonus}" Value="{x:Static model:BonusType.VLine}" />
                                            <Condition Binding="{Binding Shape}" Value="{x:Static model:ShapeType.Square}" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Data" Value="M50,15 L55,25 L53,25 L53,75 L57,75 L50,85 L43,75 L47,75 L47,25 L45,25 Z" />
                                        <Setter Property="Fill" Value="#3FA9F5" />
                                    </MultiDataTrigger>

                                    <!--  Circle Line Horizontal (стрелка ↔) -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Bonus}" Value="{x:Static model:BonusType.HLine}" />
                                            <Condition Binding="{Binding Shape}" Value="{x:Static model:ShapeType.Circle}" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Data" Value="M15,50 L25,45 L25,47 L75,47 L75,43 L85,50 L75,57 L75,53 L25,53 L25,55 Z" />
                                        <Setter Property="Fill" Value="#FF9F1C" />
                                    </MultiDataTrigger>
                                    <!--  Circle Line Vertical (стрелка ↨) -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Bonus}" Value="{x:Static model:BonusType.VLine}" />
                                            <Condition Binding="{Binding Shape}" Value="{x:Static model:ShapeType.Circle}" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Data" Value="M50,15 L55,25 L53,25 L53,75 L57,75 L50,85 L43,75 L47,75 L47,25 L45,25 Z" />
                                        <Setter Property="Fill" Value="#FF9F1C" />
                                    </MultiDataTrigger>

                                    <!--  Triangle Line Horizontal (стрелка ↔) -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Bonus}" Value="{x:Static model:BonusType.HLine}" />
                                            <Condition Binding="{Binding Shape}" Value="{x:Static model:ShapeType.Triangle}" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Data" Value="M15,50 L25,45 L25,47 L75,47 L75,43 L85,50 L75,57 L75,53 L25,53 L25,55 Z" />
                                        <Setter Property="Fill" Value="#2ECC71" />
                                    </MultiDataTrigger>
                                    <!--  Triangle Line Vertical (стрелка ↨) -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Bonus}" Value="{x:Static model:BonusType.VLine}" />
                                            <Condition Binding="{Binding Shape}" Value="{x:Static model:ShapeType.Triangle}" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Data" Value="M50,15 L55,25 L53,25 L53,75 L57,75 L50,85 L43,75 L47,75 L47,25 L45,25 Z" />
                                        <Setter Property="Fill" Value="#2ECC71" />
                                    </MultiDataTrigger>

                                    <!--  Diamond Line Horizontal (стрелка ↔) -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Bonus}" Value="{x:Static model:BonusType.HLine}" />
                                            <Condition Binding="{Binding Shape}" Value="{x:Static model:ShapeType.Diamond}" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Data" Value="M15,50 L25,45 L25,47 L75,47 L75,43 L85,50 L75,57 L75,53 L25,53 L25,55 Z" />
                                        <Setter Property="Fill" Value="#9B59B6" />
                                    </MultiDataTrigger>
                                    <!--  Diamond Line Vertical (стрелка ↨) -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Bonus}" Value="{x:Static model:BonusType.VLine}" />
                                            <Condition Binding="{Binding Shape}" Value="{x:Static model:ShapeType.Diamond}" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Data" Value="M50,15 L55,25 L53,25 L53,75 L57,75 L50,85 L43,75 L47,75 L47,25 L45,25 Z" />
                                        <Setter Property="Fill" Value="#9B59B6" />
                                    </MultiDataTrigger>

                                    <!--  Star Line Horizontal (стрелка ↔) -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Bonus}" Value="{x:Static model:BonusType.HLine}" />
                                            <Condition Binding="{Binding Shape}" Value="{x:Static model:ShapeType.Star}" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Data" Value="M15,50 L25,45 L25,47 L75,47 L75,43 L85,50 L75,57 L75,53 L25,53 L25,55 Z" />
                                        <Setter Property="Fill" Value="#F1C40F" />
                                    </MultiDataTrigger>
                                    <!--  Star Line Vertical (стрелка ↨) -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Bonus}" Value="{x:Static model:BonusType.VLine}" />
                                            <Condition Binding="{Binding Shape}" Value="{x:Static model:ShapeType.Star}" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Data" Value="M50,15 L55,25 L53,25 L53,75 L57,75 L50,85 L43,75 L47,75 L47,25 L45,25 Z" />
                                        <Setter Property="Fill" Value="#F1C40F" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Viewbox>
            </Border>
        </Button>
    </DataTemplate>

</ResourceDictionary>
