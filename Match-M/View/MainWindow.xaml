<Window
    x:Class="Match_M.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Match_M"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="clr-namespace:Match_M.Model"
    xmlns:view="clr-namespace:Match_M.View"
    xmlns:vm="clr-namespace:Match_M.ViewModel"
    Title="Match-M"
    Width="{x:Static model:GameConstants.SCREEN_WIDTH}"
    Height="{x:Static model:GameConstants.SCREEN_HEIGHT}"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Grid>
        <!-- Главное меню -->
        <view:MenuView DataContext="{Binding Menu}">
            <view:MenuView.Style>
                <Style TargetType="view:MenuView">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.GameStateService.CurrentState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Menu">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </view:MenuView.Style>
        </view:MenuView>

        <!-- Игровой экран -->
        <view:GameView DataContext="{Binding Game}">
            <view:GameView.Style>
                <Style TargetType="view:GameView">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.GameStateService.CurrentState, RelativeSource={RelativeSource AncestorType=Window}}" Value="InGame">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </view:GameView.Style>
        </view:GameView>

        <!-- Game Over -->
        <view:GameOverView DataContext="{Binding GameOver}">
            <view:GameOverView.Style>
                <Style TargetType="view:GameOverView">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.GameStateService.CurrentState, RelativeSource={RelativeSource AncestorType=Window}}" Value="GameOver">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </view:GameOverView.Style>
        </view:GameOverView>
    </Grid>
</Window>
