<Window
    x:Class="Match_M.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Match_M"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="clr-namespace:Match_M.Model"
    xmlns:view="clr-namespace:Match_M.View"
    xmlns:vm="clr-namespace:Match_M.ViewModel"
    Title="Match-M"
    Width="{x:Static model:GameConstants.SCREEN_WIDTH}"
    Height="{x:Static model:GameConstants.SCREEN_HEIGHT}"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Grid>
        <ContentControl Content="{Binding CurrentViewModel}">

            <ContentControl.Resources>

                <DataTemplate DataType="{x:Type vm:MenuViewModel}">
                    <view:MenuView />
                </DataTemplate>

                <DataTemplate DataType="{x:Type vm:GameViewModel}">
                    <view:GameView />
                </DataTemplate>

                <DataTemplate DataType="{x:Type vm:GameOverViewModel}">
                    <view:GameOverView />
                </DataTemplate>

            </ContentControl.Resources>

        </ContentControl>
    </Grid>
</Window>
