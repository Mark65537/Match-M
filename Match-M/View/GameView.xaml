<UserControl
    x:Class="Match_M.View.GameView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="clr-namespace:Match_M.Model"
    xmlns:vm="clr-namespace:Match_M.ViewModel"
    d:DataContext="{d:DesignInstance Type=vm:GameViewModel}"
    d:Height="{x:Static model:GameConstants.SCREEN_HEIGHT}"
    d:Width="{x:Static model:GameConstants.SCREEN_WIDTH}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ShapesDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="MainGrid" Background="#111">
        <Grid.RowDefinitions>
            <!--  Верхняя панель: очки + таймер  -->
            <RowDefinition Height="Auto" />
            <!--  Игровое поле  -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Верхняя панель  -->
        <StackPanel
            x:Name="TopPanel"
            Grid.Row="0"
            Margin="10"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <TextBlock
                x:Name="ScoreLabel"
                Margin="0,0,5,0"
                FontSize="24"
                Foreground="White"
                Text="Очки:" />
            <TextBlock
                x:Name="ScoreValue"
                FontSize="24"
                Foreground="Gold"
                Text="{Binding Score}" />

            <TextBlock
                x:Name="TimeLabel"
                Margin="40,0,5,0"
                FontSize="24"
                Foreground="White"
                Text="Время:" />
            <TextBlock
                x:Name="TimeValue"
                FontSize="24"
                Foreground="LightGreen"
                Text="{Binding TimeText}" />
        </StackPanel>

        <!--  Игровое поле  -->

        <Viewbox
            x:Name="BoardViewbox"
            Grid.Row="1"
            Margin="20"
            VerticalAlignment="Bottom"
            Stretch="Uniform"
            StretchDirection="Both">
            <ItemsControl x:Name="BoardItems" ItemsSource="{Binding Cells}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{x:Static model:GameConstants.BOARD_COLUMNS}" Rows="{x:Static model:GameConstants.BOARD_ROWS}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </Viewbox>
    </Grid>
</UserControl>

